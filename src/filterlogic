            "ㆍ의료/헬스케어 분야 도메인 경험이 있으신 분 -HL7, DICOM 등 의료 표준 프로토콜 이해 및 병원 시스템 연동 경험 ㆍGit, DevOps, CI/CD 파이프라인 구축 경험이 있으신 분 ㆍAWS 등 클라우드 기반 시스템 개발 및 인프라 운영 경험이 있으신 분 ㆍ프론트엔드 개발 경험이 있어 전체 서비스 흐름 이해가 빠르신 분",
          "지원 마감일": "채용시 마감",
        },
        {
          회사명: "리버에이아이",
          공고제목: "리버에이아이 - AI 신입 개발자 모집",
          출처URL:
            "https://www.saramin.co.kr/zf_user/jobs/relay/view?isMypage=no&rec_idx=54255455",
          기업규모: "중소기업",
          기업규모_코드: "C",
          근무지역: "서울 강서구",
          근무지역_코드: "1",
          근무형태: "계약직",
          학력요건: "대졸(2,3년제) 이상(예정자 가능)",
          학력_코드: "H2",
          전공요건: "",
          자격요건:
            "• 신입\\n• 대학졸업(2,3년)이상, 졸업 예정자 지원가능\\n• 논리적 문제 해결 능력\\n• 팀워크와 커뮤니케이션 원활\\n• Python 등 기초 프로그래밍 언어 지식\\n• 신기술 학습에 열정 있는 분",
          경력유형: "신입",
          경력유형_코드: "신입",
          경력연차_최소: "신입(0년)",
          경력연차_숫자: "0",
          직무명: "AI 신입 개발자",
          직무_카테고리_코드: "M4",
          주요업무_원문:
            "• 시계열 데이터 기반 AI 모델 연구 및 개발\\n• RNN, GNN 등 딥러닝 모델 실험 및 성능 개선 지원\\n• 데이터 수집, 전처리, 학습 데이터셋 구축",
          인재상_원문: "",
          우대_자격증: "",
          우대_어학기준: "",
          우대사항_원문:
            "• IT계열 대학교 졸업자 또는 졸업 예정자\\n• AI 시계열 데이터 분석 또는 예측 모델 프로젝트 경험자\\n• AI / 머신러닝 / 딥러닝에 대한 기본 이해가 있는 분",
          "지원 마감일": "2026.07.23",
        },
      ];

      // ── 코드 → 한국어 라벨 ──────────────────────────
      const REGION_LABEL = {
        1: "서울",
        2: "경기·인천",
        3: "부산·경남",
        4: "대구·경북",
        5: "대전·충청",
        6: "광주·전라",
        7: "강원",
        8: "제주",
        9: "재택·전국",
      };
      const SIZE_LABEL = {
        A: "대기업",
        B: "중견기업",
        C: "중소기업",
        D: "스타트업",
        E: "공공·교육",
      };
      const EDU_LEVEL = { H1: 1, H2: 2, H3: 3, H4: 4, H5: 5 };

      // ── 칩 선택 로직 ─────────────────────────────────
      function initChips() {
        document.querySelectorAll(".chip-group").forEach((group) => {
          const isSingle = group.id === "chips-job";
          group.querySelectorAll(".chip").forEach((chip) => {
            chip.addEventListener("click", () => {
              if (isSingle) {
                group
                  .querySelectorAll(".chip")
                  .forEach((c) => c.classList.remove("selected"));
                chip.classList.add("selected");
              } else {
                chip.classList.toggle("selected");
              }
            });
          });
        });
      }

      function getSelected(groupId) {
        return [...document.querySelectorAll(`#${groupId} .chip.selected`)].map(
          (c) => c.dataset.val,
        );
      }

      // ── 필터 로직 ────────────────────────────────────
      function runFilter() {
        const profile = {
          filter_company_size: getSelected("chips-size"),
          filter_job_major: getSelected("chips-job")[0] || null,
          filter_region: getSelected("chips-region"),
          filter_work_type: getSelected("chips-work"),
          education_level: document.getElementById("sel-edu").value || null,
          career_type: document.getElementById("sel-career-type").value || null,
          career_years: parseInt(
            document.getElementById("sel-career-years").value || "0",
          ),
        };

        const passed = [],
          majorWarnings = [];

        for (const job of JOBS) {
          const fail = [];

          // 기업규모
          if (profile.filter_company_size.length > 0) {
            if (!profile.filter_company_size.includes(job["기업규모_코드"]))
              fail.push("규모");
          }
          // 지역
          if (profile.filter_region.length > 0) {
            const isRemote =
              (job["근무지역"] || "").includes("재택") ||
              (job["근무지역"] || "").includes("전국");
            if (
              !isRemote &&
              !profile.filter_region.includes(String(job["근무지역_코드"]))
            )
              fail.push("지역");
          }
          // 직무
          if (profile.filter_job_major) {
            if (job["직무_카테고리_코드"] !== profile.filter_job_major)
              fail.push("직무");
          }
          // 근무형태
          if (profile.filter_work_type.length > 0) {
            const jdWork = job["근무형태"] || "";
            if (!profile.filter_work_type.some((t) => jdWork.includes(t)))
              fail.push("근무형태");
          }
          // 학력
          if (profile.education_level) {
            const userLv = EDU_LEVEL[profile.education_level] || 1;
            const jdLv = EDU_LEVEL[job["학력_코드"]] || 1;
            if (userLv < jdLv) fail.push("학력");
          }
          // 경력
          if (profile.career_type) {
            const jdType = job["경력유형_코드"] || "";
            const jdYears = parseInt(job["경력연차_숫자"] || "0");
            if (profile.career_type === "신입") {
              if (!jdType.includes("신입") && !jdType.includes("무관"))
                fail.push("경력");
            } else {
              if (
                !jdType.includes("경력") &&
                !jdType.includes("무관") &&
                !jdType.includes("신입+경력")
              )
                fail.push("경력");
              else if (profile.career_years < jdYears) fail.push("연차");
            }
          }
          // 전공 SOFT
          const jdMajor = job["전공요건"] || "";
          if (jdMajor && !jdMajor.includes("무관") && jdMajor.trim() !== "") {
            majorWarnings.push(job);
          }

          if (fail.length === 0) passed.push(job);
        }

        renderResult(passed, majorWarnings);
      }

      // ── 결과 렌더링 ──────────────────────────────────
      function renderResult(passed, warnings) {
        document.getElementById("pass-count").textContent = passed.length;

        // 전공 경고
        const wb = document.getElementById("warning-box");
        if (warnings.length > 0) {
          wb.innerHTML = `<div class="major-warning">⚠️ 전공 요건이 있는 공고 ${warnings.length}개 포함 — 실무 경험으로 대체 가능한 경우가 많아 필터에서 제외하지 않았어요.</div>`;
        } else {
          wb.innerHTML = "";
        }

        const list = document.getElementById("card-list");
        if (passed.length === 0) {
          list.innerHTML = `<div class="empty-state"><div class="emoji">🫧</div><p>조건을 만족하는 공고가 없어요.<br>필터를 조금 넓혀볼까요?</p></div>`;
        } else {
          list.innerHTML = passed
            .map((job) => {
              const regionLabel =
                REGION_LABEL[job["근무지역_코드"]] || job["근무지역"] || "";
              const sizeLabel =
                SIZE_LABEL[job["기업규모_코드"]] || job["기업규모"] || "";
              const careerLabel =
                job["경력유형_코드"] === "신입"
                  ? "신입"
                  : job["경력연차_숫자"] > 0
                    ? `경력 ${job["경력연차_숫자"]}년↑`
                    : "경력무관";
              const url = job["출처URL"] || "#";

              return `<a class="card" href="${url}" target="_blank" rel="noopener">
        <div class="card-top">
          <div>
            <div class="card-company">${sizeLabel} · ${job["회사명"]}</div>
            <div class="card-title">${job["공고제목"]}</div>
          </div>
          <div class="card-match">매칭</div>
        </div>
        <div class="card-tags">
          <span class="tag region">📍 ${regionLabel}</span>
          <span class="tag work">${job["근무형태"]}</span>
          <span class="tag career">${careerLabel}</span>
        </div>
        <div class="card-link">공고 원본 보기 →</div>
      </a>`;
            })
            .join("");
        }

        // 화면 전환
        document.getElementById("filter-screen").classList.remove("active");
        document.getElementById("result-screen").classList.add("active");
        window.scrollTo(0, 0);
      }

      function goBack() {
        document.getElementById("result-screen").classList.remove("active");
        document.getElementById("filter-screen").classList.add("active");
        window.scrollTo(0, 0);
      }

      // 초기화
      initChips();
    </script>
  </body>
</html>
