# ============================================================
# 뽑아듀오 — 환경 변수 예시 파일 (.env.example)
# ============================================================
# 이 파일을 복사해 .env 파일로 저장하고,
# 아래 항목을 직접 입력하세요.
#
#   cp .env.example .env
#
# 주의: .env 파일은 절대 Git에 커밋하지 마세요.
#       .gitignore 에 .env 가 포함되어 있는지 확인하세요.
# ============================================================


# ── 공공기관 채용정보 API Key ──────────────────────────────
# 발급 경로 예시:
#   알리오(ALIO):   https://alio.go.kr/  → API 서비스 신청
#   공공데이터포털:  https://www.data.go.kr/ → 오픈API → 인증키 발급
#   워크넷(Work24): https://www.work24.go.kr/ → OpenAPI 신청
#
# 발급받은 키를 아래 = 오른쪽에 붙여넣으세요. 따옴표 없이 입력합니다.
PUBLIC_JOB_API_KEY=여기에_발급받은_API_KEY_입력


# ── 서버 포트 ──────────────────────────────────────────────
# 기본값: 3000 (변경 불필요 시 그대로 두세요)
PORT=3000
